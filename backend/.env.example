# Local PostgreSQL
DB_NAME=tennis_db
DB_USER=postgres
DB_PASSWORD=your_password
DB_HOST=127.0.0.1
DB_PORT=5432

# Railway: paste DATABASE_URL from Postgres service (overrides fields above)
# DATABASE_URL=postgresql://user:pass@host:port/railway
# DB_SSLMODE=require

# CORS — comma-separated frontend URLs (Vercel + localhost)
# ALLOWED_ORIGINS=http://localhost:3000,https://your-app.vercel.app
